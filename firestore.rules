rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      let docPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(docPath) ? get(docPath).data : null;
    }

    function isSuperAdmin() {
      let superAdmins = ["ns.5.empresarial@gmail.com", "luissalberto26@gmail.com"];
      let data = getUserData();
      let roleIsSuper = data != null && data.role == 'Super Administrador';
      let emailIsSuper = request.auth.token.email != null && request.auth.token.email in superAdmins; // Removed email_verified check because Google signin without verification fails here
      return isAuthenticated() && (roleIsSuper || emailIsSuper);
    }

    function isCampusAdmin() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'Administrador de Sede';
    }

    function isTeacher() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'Profesor';
    }

    function isAdmin() {
      return isSuperAdmin() || isCampusAdmin();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isOwnerByEmail() {
      return isAuthenticated() && request.auth.token.email == resource.data.email;
    }

    // ===============================================================
    // Rules for Collections
    // ===============================================================

    match /campuses/{campusId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /admins/{adminId} {
      allow read: if true;
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (isOwnerByEmail() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatar', 'tempPassword']));
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isOwnerByEmail() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatar', 'tempPassword']));
    }

    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isOwnerByEmail() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatar', 'tempPassword']));
    }

    match /grades/{gradeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /communications/{communicationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.recipientId);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.recipientId);
      allow delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /concepts/{conceptId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /user_settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(request.resource.data.user_id);
    }

    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }

    // User profiles for role checking
    match /users/{userId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isOwner(userId);
    }
  }
}
